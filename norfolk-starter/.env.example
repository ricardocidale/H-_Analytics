# ── Database ────────────────────────────────────────────────────────────
# Local: use docker compose (see docker-compose.yml)
# Production: Neon PostgreSQL (use pooled connection string for serverless)
DATABASE_URL=postgresql://norfolk:norfolk@localhost:5432/norfolk_dev?schema=public

# ── Clerk Authentication ────────────────────────────────────────────────
# https://dashboard.clerk.com → your app → API Keys
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ── Add your project-specific keys below ────────────────────────────────
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
