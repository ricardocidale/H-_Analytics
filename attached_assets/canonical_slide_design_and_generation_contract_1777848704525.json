{
  "report_name": "Canonical slide design analysis and generation contract",
  "version": "2.0_single_file",
  "source_file": "L+B Property 6-Slide Cannonical.pdf",
  "purpose": "Use this single JSON file as the canonical design contract for generating new slides that match the original 6-slide deck.",
  "coordinate_system": {
    "canvas_width": 960,
    "canvas_height": 540,
    "units": "PDF points",
    "origin": "top-left",
    "x_axis": "left-to-right",
    "y_axis": "top-to-bottom",
    "slide_numbering_rule": "Use slide_number only. Do not call slides pages."
  },
  "critical_instruction_for_receiving_agent": {
    "single_source_of_truth": "This JSON is the design contract. Use it instead of any app theme, UI library theme, browser defaults, generic presentation templates, or default components.",
    "slide_numbering": "Use Slide 1, Slide 2, etc. Never use page number terminology in generated slides or internal mapping.",
    "property_title_rule": "For each generated slide, replace property_name_at_slide_title with the new user-provided property name while preserving the canonical typography, position, hierarchy, and visual treatment.",
    "theme_rule": "Any rebuilt or newly generated slides MUST use the design_theme object and per-slide layout specs in this JSON.",
    "layout_rule": "Treat every slide as a fixed 960x540 editorial presentation canvas. Do not use responsive app layouts.",
    "precision_rule": "Preserve relative hierarchy, bounding boxes, image treatments, captions, cards, badges, footers, and colors. If content changes, adapt text within existing design constraints rather than redesigning."
  },
  "generation_contract": {
    "source_of_truth_priority": [
      "1. design_theme",
      "2. slide_layouts and per-slide element specs",
      "3. user-provided replacement content",
      "4. fallback approximation only where exact source information is unavailable"
    ],
    "required_behavior": [
      "Use 960x540 canvas.",
      "Use slide_number, never page number.",
      "Use the property_name_at_slide_title field as the property-name placement role.",
      "Use the canonical palette exactly.",
      "Use the canonical typography hierarchy.",
      "Use the canonical photo crop and caption treatments.",
      "Use the canonical card, footer, badge, and grid systems.",
      "Preserve slide-specific layout identity."
    ],
    "forbidden_behavior": [
      "Do not use app theme colors.",
      "Do not use default UI components.",
      "Do not use generic dashboard widgets.",
      "Do not use generic responsive grids.",
      "Do not use Material UI, Bootstrap, Tailwind, shadcn, or browser default component styling unless manually restyled to exactly match the canonical deck.",
      "Do not replace the editorial financial tables with spreadsheet UI tables.",
      "Do not generate ###### as a financial value.",
      "Do not rename slides as pages.",
      "Do not flatten all slide types into the same template."
    ],
    "overflow_handling_rules": [
      "If new text is longer than canonical text, first wrap within the original bounding box.",
      "If wrapping is insufficient, reduce font size slightly while preserving hierarchy.",
      "If still insufficient, tighten line spacing minimally.",
      "Only expand or move bounding boxes as a last resort.",
      "Never allow text to overlap important images, captions, or financial values.",
      "Financial values must remain readable; never output clipped values or ######."
    ],
    "quality_control_checklist": [
      "Every generated slide is labeled by slide_number.",
      "The property name is placed in the correct canonical property-title role.",
      "All colors come from design_theme.palette.",
      "Typography resembles Georgia/Poppins hierarchy from the canonical deck.",
      "Photos use canonical rounded crops and dark caption strips.",
      "Cards, section headers, footers, badges, icons, and grid backgrounds are preserved.",
      "No default UI components or app-themed elements are visible.",
      "Financial values are readable and not clipped.",
      "Slide still looks like the Lola & Ber canonical deck."
    ]
  },
  "variable_content_schema": {
    "common_fields": {
      "slide_number": "integer matching canonical layout to use",
      "property_name": "string replacing property_name_at_slide_title",
      "slide_title": "string replacing slide_title_text where requested",
      "slide_subtitle": "string replacing slide_subtitle_text where requested",
      "category_badge": "string or null",
      "footer_tagline": "string",
      "images": "array of image objects mapped to visual_elements ids",
      "captions": "object keyed by visual element id"
    },
    "slide_1_or_2_property_spotlight_fields": {
      "asking_price": "string",
      "target_acquisition": "string",
      "property_specs": "array of bullet strings",
      "vision_bullets": "array of bullet strings",
      "location": "string",
      "acreage": "string",
      "bed_bath": "string optional",
      "amenities": "array optional"
    },
    "slide_3_expansion_fields": {
      "concept_summary": "string",
      "model": "string",
      "strategic_details": "array of label/value strings",
      "brand_travels": "string",
      "why_this_model": "array of rationale blocks"
    },
    "slide_4_pipeline_fields": {
      "pipeline_cards": "exactly six objects with category, name, target_acquisition, image, and optional description",
      "strategic_filter": "string"
    },
    "slide_5_transformation_fields": {
      "comparison_table": "rows for Feature, Existing, Proposed",
      "stable_year_snapshot": "array of item/value pairs",
      "key_investor_metrics": "array of bullet strings",
      "financing_summary": "array of item/value pairs",
      "footnote": "string"
    },
    "slide_6_financial_fields": {
      "years": "array of years",
      "income_statement_rows": "array of label and yearly values",
      "cost_rows": "array of label and yearly values",
      "financial_warning": "Never allow clipped values or ######."
    }
  },
