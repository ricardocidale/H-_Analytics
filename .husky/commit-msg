#!/usr/bin/env sh
# commit-msg hook — reject generic / uninformative commit messages.
#
# Context: `rewritetax.md` found 141 empty-or-generic commit messages in repo
# history (single-char "c", "commit", "com", "wip", etc.). Each ran a full CI
# + verify cycle for zero documented change. This hook ends that waste class.
#
# The first line (subject) must be:
#   - At least 15 characters (after trimming)
#   - Not match a blocklist of common low-effort messages
#
# The full message body can still be short; this only checks the subject line.

msg_file="$1"
subject=$(head -n 1 "$msg_file" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')

# Allow merge commits, reverts, and co-author-only amends to pass
case "$subject" in
  "Merge "*|"Revert "*|"fixup! "*|"squash! "*) exit 0 ;;
esac

# Minimum length check
if [ ${#subject} -lt 15 ]; then
  echo "❌ Commit subject too short (${#subject} chars): '$subject'"
  echo "   Minimum 15 chars. Describe WHAT changed and WHY briefly."
  echo "   Use --no-verify only for emergencies and follow up with a descriptive amend."
  exit 1
fi

# Blocklist of low-effort subjects (exact match, case-insensitive)
subject_lower=$(printf '%s' "$subject" | tr '[:upper:]' '[:lower:]')
case "$subject_lower" in
  "c"|"com"|"commit"|"commit."|"wip"|"wip."|"fix"|"fix."|"update"|"update."|"save"|"save."|"checkpoint"|"checkpoint."|"progress"|"progress."|"saved progress at the end of the loop")
    echo "❌ Commit subject matches the blocklist: '$subject'"
    echo "   This looks like a low-effort auto-message. Rewrite to describe the change."
    exit 1
    ;;
esac

exit 0
