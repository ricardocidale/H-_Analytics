modules = ["nodejs-24", "python-3.11", "python3", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "vm"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "check:spinner-contrast"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "check:replit-independence"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "check:magic-numbers"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test:calc"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "check:production-image"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "check:migration-guards"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "check:types-mirror"

[[workflows.workflow]]
name = "check:spinner-contrast"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/scripts run check:spinner-contrast"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "check:replit-independence"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/scripts run check:replit-independence"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "check:magic-numbers"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/scripts run check:magic-numbers"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "test:calc"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/calc run test"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "check:production-image"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/scripts run check:production-image"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "check:migration-guards"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/scripts run check:migration-guards"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "check:types-mirror"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/scripts run check:types-mirror"

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["linear:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 90000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 23312
externalPort = 3000

[[ports]]
localPort = 23636
externalPort = 3001

[[ports]]
localPort = 25092
externalPort = 3002

[userenv]

[userenv.shared]
STORAGE_PROVIDER = "r2"
AUTH_PROVIDER = "replit"
NODE_ENV = "production"
CI = "true"

[nix]
channel = "stable-25_05"
packages = ["freetype", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "tcl", "tk", "zlib"]
