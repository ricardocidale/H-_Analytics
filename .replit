modules = ["nodejs-20", "web", "javascript", "python-3.12", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = [
  "cairo",
  "expat",
  "fontconfig",
  "freetype",
  "glib",
  "harfbuzz",
  "lcms2",
  "libimagequant",
  "libjpeg",
  "libtiff",
  "libwebp",
  "libxcrypt",
  "openjpeg",
  "pango",
  "zlib",
]

[env]
PORT = "5000"

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["node", "./dist/index.cjs"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Parity Check"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Magic Numbers Check"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Health Check"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run health"

[[workflows.workflow]]
name = "Run Tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run test:summary"

[[workflows.workflow]]
name = "Verify Financials"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run verify:summary"

[[workflows.workflow]]
name = "Lint Check"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run lint:summary"

[[workflows.workflow]]
name = "Quick Audit"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run audit:quick"

[[workflows.workflow]]
name = "Exports Check"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run exports:check"

[[workflows.workflow]]
name = "Parity Check"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "tsx script/parity-check.ts"

[[workflows.workflow]]
name = "Magic Numbers Check"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "tsx script/check-magic-numbers.ts"

[workflows.workflow.metadata]
outputType = "console"

[agent]
mockupState = "FULLSTACK"
integrations = [
  "javascript_database:1.0.0",
  "javascript_object_storage:2.0.0",
  "github:1.0.0",
  "javascript_openai_ai_integrations:2.0.0",
  "javascript_anthropic_ai_integrations:2.0.0",
  "javascript_gemini_ai_integrations:2.0.0",
  "google-sheet:1.0.0",
  "google-mail:1.0.0",
  "stripe:2.0.0",
  "javascript_log_in_with_replit:2.0.0",
  "google-drive:1.0.0",
  "google-docs:1.0.0",
  "google-calendar:1.0.0",
  "twilio:1.0.0",
  "elevenlabs:1.0.0",
  "linear:1.0.0",
]

[userenv]

[userenv.development]
PRODUCTION_URL = "https://h-analysis.com"

[userenv.shared]
GOOGLE_CLIENT_ID = "565834167960-l2lj72aphqdmhmvm88j657d8ccg6r797.apps.googleusercontent.com"
STORAGE_PROVIDER = "r2"
CI = "true"

[postMerge]
path = "script/post-merge.sh"
timeoutMs = 60000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 23636
externalPort = 3001
