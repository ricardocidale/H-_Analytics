modules = ["nodejs-24", "python-3.11", "python3", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "check:spinner-contrast"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "check:replit-independence"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "check:magic-numbers"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "API Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "L+B Property Slides"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "H+ Analytics"

[[workflows.workflow]]
name = "check:spinner-contrast"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/scripts run check:spinner-contrast"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "check:replit-independence"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/scripts run check:replit-independence"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "check:magic-numbers"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/scripts run check:magic-numbers"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "API Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/api-server run dev"
waitForPort = 8080

[[workflows.workflow]]
name = "L+B Property Slides"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=25092 BASE_PATH=/property-slides/ pnpm --filter @workspace/property-slides run dev"
waitForPort = 25092

[[workflows.workflow]]
name = "H+ Analytics"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=23312 BASE_PATH=/ pnpm --filter @workspace/hospitality-business-portal run dev"
waitForPort = 23312

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["linear:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 90000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 23312
externalPort = 3000

[[ports]]
localPort = 23636
externalPort = 3001

[[ports]]
localPort = 25092
externalPort = 3002

[userenv]

[userenv.shared]
STORAGE_PROVIDER = "r2"
AUTH_PROVIDER = "replit"
NODE_ENV = "production"
CI = "true"

[nix]
channel = "stable-25_05"
packages = ["freetype", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "tcl", "tk", "zlib"]
