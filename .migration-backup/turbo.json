{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "outputs": ["dist/**", ".tsbuildinfo"]
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "outputs": [".tsbuildinfo"]
    },
    "verify:summary": {
      "dependsOn": ["build"],
      "outputs": ["test-artifacts/**"]
    }
  }
}
