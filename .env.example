# === Database ===
DATABASE_URL=postgresql://user:password@localhost:5432/hanalytics

# === Authentication ===
SESSION_SECRET=your-session-secret-here
ADMIN_PASSWORD=your-admin-password
AUTH_PROVIDER=replit  # replit | local

# === AI Providers ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_AI_API_KEY=AIza...

# === Vector Database ===
PINECONE_API_KEY=your-pinecone-key
PINECONE_INDEX=h-analytics
PINECONE_REGION=us-east-1

# === Object Storage ===
STORAGE_PROVIDER=replit  # replit | s3
# S3_BUCKET=your-bucket
# S3_REGION=us-east-1
# S3_ACCESS_KEY_ID=...
# S3_SECRET_ACCESS_KEY=...

# === Monitoring ===
# SENTRY_DSN=https://...
# POSTHOG_KEY=phc_...

# === Caching ===
# UPSTASH_REDIS_URL=redis://...

# === Email ===
# RESEND_API_KEY=re_...

# === App ===
# APP_URL=https://your-domain.com
# PORT=5000

# === Replit (auto-configured when running on Replit) ===
# REPL_ID=...
# REPLIT_DOMAINS=...
# PUBLIC_OBJECT_SEARCH_PATHS=...
# PRIVATE_OBJECT_DIR=...
# ISSUER_URL=https://replit.com/oidc
