# === Database ===
# The app reads `POSTGRES_URL` first and falls back to `DATABASE_URL`
# (see `shared/db-url.ts`). On Replit, `DATABASE_URL` is reserved for the
# managed Helium Postgres and cannot be overridden via the Secrets UI, so
# the canonical variable across hosts is `POSTGRES_URL`.
#   • Replit (Helium):   leave POSTGRES_URL unset, use Replit's DATABASE_URL
#   • Replit (Neon):     set POSTGRES_URL to the Neon URL (DATABASE_URL stays Helium, ignored)
#   • Vercel + Neon:     set POSTGRES_URL (Vercel's Neon integration uses this name natively)
#   • Local / CI:        either works; POSTGRES_URL is the convention going forward
POSTGRES_URL=postgresql://user:password@host:5432/hanalytics?sslmode=require
# DATABASE_URL=postgresql://user:password@localhost:5432/hanalytics  # legacy fallback

# === Authentication ===
SESSION_SECRET=your-session-secret-here
ADMIN_PASSWORD=your-admin-password
AUTH_PROVIDER=replit  # replit | local

# === AI Providers ===
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_AI_API_KEY=AIza...

# === Vector Database ===
# pgvector extension on the same Postgres instance (POSTGRES_URL or DATABASE_URL,
# resolved by `shared/db-url.ts`) — no separate key required.
# OpenAI embeddings for ingest: OPENAI_API_KEY above covers it.

# === Object Storage ===
# Cloudflare R2 is the source of truth post-cutover (April 24, 2026). The
# `replit` adapter remains for rollback only — do not use for new deployments.
STORAGE_PROVIDER=r2  # r2 | s3 | replit (rollback) | local
# --- Generic S3 (AWS, MinIO, DigitalOcean Spaces) ---
# S3_BUCKET=your-bucket
# S3_REGION=us-east-1
# S3_ENDPOINT=https://...     # required for non-AWS S3-compatible providers
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# S3_PUBLIC_URL_BASE=https://cdn.example.com
# S3_FORCE_PATH_STYLE=true    # for MinIO
# --- Cloudflare R2 shortcut (STORAGE_PROVIDER=r2) ---
# Endpoint is auto-derived as https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# R2_ACCOUNT_ID=...
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET=your-bucket
# R2_PUBLIC_URL_BASE=https://pub-<hash>.r2.dev   # optional, for public URLs

# === Monitoring ===
# SENTRY_DSN=https://...
# POSTHOG_KEY=phc_...

# === Caching ===
# UPSTASH_REDIS_URL=redis://...

# === Email ===
# RESEND_API_KEY=re_...

# === Hotel Data (Amadeus free tier — 2-10K req/month) ===
# AMADEUS_CLIENT_ID=your-amadeus-client-id
# AMADEUS_CLIENT_SECRET=your-amadeus-client-secret

# === App ===
# APP_URL=https://your-domain.com
# PORT=5000

# === Replit (auto-configured when running on Replit) ===
# REPL_ID=...
# REPLIT_DOMAINS=...
# PUBLIC_OBJECT_SEARCH_PATHS=...
# PRIVATE_OBJECT_DIR=...
# ISSUER_URL=https://replit.com/oidc
